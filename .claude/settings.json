{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(ruff *)",
      "Bash(pytest *)",
      "Bash(python -m pytest *)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(git stash*)",
      "Bash(ls *)",
      "Bash(pip list*)",
      "Bash(pip show*)",
      "Bash(uv run *)",
      "Read",
      "Glob",
      "Grep",
      "Skill"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(rm -fr *)",
      "Bash(sudo *)",
      "Bash(mkfs *)",
      "Bash(dd *)",
      "Bash(curl * | bash*)",
      "Bash(curl *|bash*)",
      "Bash(wget * | bash*)",
      "Bash(wget *|bash*)",
      "Bash(> /dev/sda*)",
      "Bash(:(){:|:&};:*)",
      "Bash(chmod -R 777*)",
      "Bash(eval *)",
      "Bash(git push --force*)",
      "Bash(git push *--force*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -fd*)",
      "Bash(pip install * --break-system-packages*)",

      "Edit(~/.bashrc)",
      "Edit(~/.zshrc)",
      "Edit(~/.profile)",
      "Edit(~/.ssh/**)",

      "Read(~/.ssh/**)",
      "Read(~/.gnupg/**)",
      "Read(~/.aws/**)",
      "Read(~/.azure/**)",
      "Read(~/.config/gh/**)",
      "Read(~/.git-credentials)",
      "Read(~/.docker/config.json)",
      "Read(~/.kube/**)",
      "Read(~/.npmrc)",
      "Read(~/.pypirc)",
      "Read(~/.netrc)"
    ]
  }
}
